# CodeValdAI — Environment Variables
# Copy this file to .env and fill in the values for local development.

# gRPC server listen port
CODEVALDAI_GRPC_PORT=50056

# ArangoDB connection
CODEVALDAI_ARANGO_URL=http://localhost:8529
CODEVALDAI_ARANGO_USER=root
CODEVALDAI_ARANGO_PASSWORD=
CODEVALDAI_ARANGO_DB=codevald_demo

# Anthropic LLM API key
ANTHROPIC_API_KEY=

# CodeValdPubSub gRPC address (for event subscriptions)
PUBSUB_GRPC_ADDR=localhost:50057

# CodeValdCross gRPC address (for service registration)
CODEVALDAI_CROSS_ADDR=localhost:50052

# Agency this instance serves (used for Cross registration and schema seeding)
CODEVALDAI_AGENCY_ID=
